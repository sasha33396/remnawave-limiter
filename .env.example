# Base URL of your Remnawave panel (required)
REMNAWAVE_API_URL=https://your-panel.example.com

# API token for authentication (required)
REMNAWAVE_API_TOKEN=your-api-token-here

# Optional cookie auth, semicolon-separated key=value pairs (e.g. "session=abc;token=xyz")
REMNAWAVE_COOKIES=

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Chat ID where alerts are sent (required, use negative for groups)
TELEGRAM_CHAT_ID=-1001234567890

# Topic/thread ID for supergroups with topics enabled (0 = disabled)
TELEGRAM_THREAD_ID=0

# Comma-separated Telegram user IDs allowed to press action buttons (required)
TELEGRAM_ADMIN_IDS=111111111,222222222

# Interface language: "ru" or "en"
LANGUAGE=ru

# How often to poll nodes for active connections (seconds)
# Lower = faster detection but more API load. 60s is a good balance.
CHECK_INTERVAL=60

# Time window to consider an IP as "active" (seconds)
# IPs not seen within this window are ignored. Should be >= 2x CHECK_INTERVAL
# to reliably capture connections across polling cycles.
# 180s = 3 min, covers 3 check cycles at CHECK_INTERVAL=60
ACTIVE_IP_WINDOW=180

# Minimum time between violation detections for the same user (seconds)
# Prevents counting the same ongoing violation multiple times in rapid succession.
# With VIOLATION_THRESHOLD=3 and COOLDOWN=300, it takes at least 15 min
# of sustained violation before action is triggered.
COOLDOWN=300

# How long to cache user details from API (seconds)
# User data (username, limits) rarely changes, so 10 min is safe.
USER_CACHE_TTL=600

# Extra connections allowed above the user's device limit before flagging
# Set to 1 to account for brief overlaps during device switches
TOLERANCE=1

# Proportional tolerance multiplier (added on top of TOLERANCE)
# Effective tolerance = TOLERANCE + floor(limit * TOLERANCE_MULTIPLIER)
# Example: limit=9, TOLERANCE=1, TOLERANCE_MULTIPLIER=0.3 → effective tolerance = 1 + floor(2.7) = 3
# 0 = disabled (only fixed TOLERANCE is used)
TOLERANCE_MULTIPLIER=0

# Fallback device limit when user has no explicit limit set in the panel
# 0 = skip users without explicit limits (treat as unlimited)
DEFAULT_DEVICE_LIMIT=0

# Number of violations required before taking action (1 = act immediately)
# Higher values give users a chance to self-correct before being penalized.
VIOLATION_THRESHOLD=3

# Time window for counting violations toward the threshold (seconds)
# 3600 = 1 hour. Counter resets if no new violation occurs within this window.
# With COOLDOWN=300 and THRESHOLD=3: action triggers after 3 detections
# spread over 10-60 min of sustained abuse.
VIOLATION_THRESHOLD_WINDOW=3600

# "manual" = send Telegram alert with action buttons (admin decides)
# "auto"   = automatically disable subscription + send informational alert
ACTION_MODE=manual

# How long to disable subscription in auto mode (minutes)
# 0 = permanent (until manually re-enabled)
# In manual mode, this adds a "Disable for N min" button alongside "Disable permanently"
AUTO_DISABLE_DURATION=15

# Comma-separated user IDs to never flag (persisted in Redis, survives restarts)
WHITELIST_USER_IDS=

# Group IPs by /24 subnet (IPv4) or /48 (IPv6) when counting devices
# Useful when users get multiple IPs from the same ISP/carrier
# true = count unique subnets instead of unique IPs
SUBNET_GROUPING=false

# URL to send violation events via POST (empty = disabled)
WEBHOOK_URL=

# HMAC-SHA256 secret for signing webhook payloads (sent in X-Webhook-Signature header)
WEBHOOK_SECRET=

# Redis connection URL (used for caching, cooldowns, violation counters, whitelist)
REDIS_URL=redis://redis:6379

# Timezone for timestamps in alerts (IANA format)
TIMEZONE=UTC
